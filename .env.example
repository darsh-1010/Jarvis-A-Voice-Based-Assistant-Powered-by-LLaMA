# ──────────────────────────────────────────────────────────────────────────────
# Jarvis — Environment Configuration Template
# Copy this file to .env at the project root and fill in your values.
# NEVER commit the .env file — it is listed in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ── AI API Keys ───────────────────────────────────────────────────────────────

# NewsAPI key — required for news fetching (https://newsapi.org/)
NEWS_API_KEY=

# Google Gemini API key (https://aistudio.google.com/)
GEMINI_API_KEY=

# OpenRouter API key — multi-model fallback (https://openrouter.ai/)
OPENROUTER_API_KEY=

# ── Provider Settings ─────────────────────────────────────────────────────────

# Primary AI provider to use: "gemini", "openrouter", or "ollama"
# Fallback chain is always: gemini → openrouter → ollama
DEFAULT_PROVIDER=gemini

# Ollama local model name (used when DEFAULT_PROVIDER=ollama or as last resort)
# OLLAMA_MODEL=gemma2:2b

# Gemini model name
# GEMINI_MODEL=gemini-1.5-flash

# OpenRouter model name
# OPENROUTER_MODEL=google/gemma-2-9b-it:free

# ── Memory / Redis ────────────────────────────────────────────────────────────

# Set USE_REDIS=true to persist conversation history across sessions
USE_REDIS=false
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# ── Audio Settings ────────────────────────────────────────────────────────────

# Speech rate (words per minute) — default 175
# SPEECH_RATE=175

# Speech volume (0.0 – 1.0) — default 1.0
# SPEECH_VOLUME=1.0

# Voice ID index from pyttsx3 voices list — default 0
# VOICE_ID=0

# ── Wake Word ─────────────────────────────────────────────────────────────────

# The word Jarvis listens for before accepting commands — default "jarvis"
# WAKE_WORD=jarvis

# ── Weather (https://openweathermap.org/api — free tier: 1,000 calls/day) ────

OPENWEATHERMAP_API_KEY=
# Default city for weather queries when no city is spoken
USER_CITY=Mumbai

# ── Finance — Stocks (https://alphavantage.co — free tier: 25 calls/day) ─────

ALPHA_VANTAGE_API_KEY=

# ── Spotify Web API (https://developer.spotify.com — requires Premium) ───────
# Register an app at the Spotify Developer Dashboard to get these values.

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Must match the Redirect URI configured in your Spotify app settings
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback

# ── Google Services — Calendar & Gmail ───────────────────────────────────────
# Download OAuth2 credentials JSON from Google Cloud Console.
# Enable "Google Calendar API" and "Gmail API" in the same project.
# The token is cached automatically after first browser-based login.

# Path to the downloaded credentials JSON file (relative to backend/)
GOOGLE_CREDENTIALS_PATH=./google_credentials.json

